<Window x:Class="RoomBooking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Rezerwacji" Height="400" Width="600">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="RoomsList" ItemsSource="{Binding Rooms}" DisplayMemberPath="Name" Margin="5"/>

        <StackPanel Grid.Column="1" Margin="15,5,5,5">
            <TextBlock Text="{Binding ElementName=RoomsList, Path=SelectedItem.Name}" FontSize="24" FontWeight="Bold"/>

            <TextBlock Text="Status:" Margin="0,10,0,0" Foreground="Gray"/>

            <TextBlock Text="{Binding ElementName=RoomsList, Path=SelectedItem.Status}" 
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Red"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=RoomsList, Path=SelectedItem.Status}" Value="WOLNA">
                                <Setter Property="Foreground" Value="Green"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="Imię:"/>
            <TextBox x:Name="txtImie" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Nazwisko:"/>
            <TextBox x:Name="txtNazwisko" Margin="0,5,0,20" Height="25"/>

            <Button Content="ZAREZERWUJ" Click="BookButton_Click" Height="40" Margin="0,0,0,10" Background="LightGreen"/>
            <Button Content="ANULUJ REZERWACJĘ" Click="CancelButton_Click" Height="40" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>