<Window x:Class="RoomBooking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Rezerwacji Sal" Height="550" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F4F7FC" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#2C3E50" Grid.Row="0">
            <TextBlock Text="ZARZĄDZANIE REZERWACJAMI" Foreground="White" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="25,0,0,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Filtruj status sal:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                        <ComboBox x:Name="FilterCombo" SelectionChanged="FilterCombo_SelectionChanged" Padding="5" FontSize="14">
                            <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                            <ComboBoxItem Content="Wolna"/>
                            <ComboBoxItem Content="Zajęta"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                    </Border.Effect>

                    <ListBox x:Name="RoomsList" ItemsSource="{Binding Rooms}" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,0,0,5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="TextElement.Foreground" Value="#1565C0"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="{Binding Status}" FontSize="12" Margin="0,3,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="WOLNA">
                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.05"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="SZCZEGÓŁY SALI" FontWeight="Bold" FontSize="12" Foreground="#95A5A6" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding ElementName=RoomsList, Path=SelectedItem.Name}"
                               FontSize="28" FontWeight="ExtraBold" Foreground="#2C3E50"/>

                    <TextBlock Text="{Binding ElementName=RoomsList, Path=SelectedItem.Status}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,5,0,25">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#E74C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=RoomsList, Path=SelectedItem.Status}" Value="WOLNA">
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Separator Margin="0,0,0,25" Background="#ECF0F1"/>
                    <TextBlock Text="DANE REZERWUJĄCEGO" FontWeight="Bold" FontSize="12" Foreground="#95A5A6" Margin="0,0,0,15"/>

                    <TextBlock Text="Imię:" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBox x:Name="txtImie" Margin="0,5,0,15" Height="38" VerticalContentAlignment="Center" Padding="10,0"
                             BorderBrush="#BDC3C7" BorderThickness="1" FontSize="14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Nazwisko:" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBox x:Name="txtNazwisko" Margin="0,5,0,30" Height="38" VerticalContentAlignment="Center" Padding="10,0"
                             BorderBrush="#BDC3C7" BorderThickness="1" FontSize="14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Content="ZAREZERWUJ SALĘ" Click="BookButton_Click"
                            Height="45" Margin="0,0,0,12"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="ANULUJ REZERWACJĘ" Click="CancelButton_Click"
                            Height="45" Background="Transparent" Foreground="#E74C3C" BorderBrush="#E74C3C" BorderThickness="2" FontWeight="Bold" FontSize="14">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>